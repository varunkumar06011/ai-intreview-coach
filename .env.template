# AI Interview Coach - Configuration Template
# Rename this file to '.env' and place it in the 'backend' folder (or root folder).

# Set to enable Gemini Live AI Engine (Recommended - Google 2.5 Flash)
GEMINI_API_KEY=

# Set to enable OpenAI Live AI Engine (gpt-4o-mini)
OPENAI_API_KEY=

# Set to enable OpenRouter Live AI Engine (e.g. for free high-parameter models)
OPENROUTER_API_KEY=
# Define the model, e.g. "liquid/lfm-40b:free" or a 120B model from OpenRouter
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
